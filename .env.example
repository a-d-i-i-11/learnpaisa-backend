# ── SERVER ──
PORT=5000
NODE_ENV=production

# ── DATABASE (MongoDB Atlas - FREE) ──
MONGODB_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/learnpaisa

# ── JWT SECRET (make this a long random string) ──
JWT_SECRET=learnpaisa_super_secret_key_change_this_2025

# ── RAZORPAY (from razorpay.com dashboard) ──
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── OTP (using fast2sms.com - FREE 50 SMS/day) ──
FAST2SMS_API_KEY=YOUR_FAST2SMS_KEY
